#!/bin/bash

# Exit on error
set -e

# Check if Containerfile path is provided
if [ $# -ne 1 ]; then
    echo "Usage: $0 path/to/Containerfile"
    exit 1
fi

# skopeo is required for safe tag number calculation; abort early if missing
if ! command -v skopeo &>/dev/null; then
    echo "Error: skopeo is not installed. Install it before running this script."
    exit 1
fi

CONTAINERFILE="$1"
REGISTRY="docker.io"
NAMESPACE="phybuilder"
PASSWORD=$(cat ~/sync/env/password_dockerhub_phybuilder)

# Extract image name from path (remove Containerfile and convert / to -)
IMAGE_NAME=$(dirname "$CONTAINERFILE" | tr '/' '-' | sed 's/^-//')

# Sync release tags from upstream before computing the next tag number.
# Without this, another machine's releases are invisible locally and the same
# phy tag can be reused, overwriting the registry image.
echo "Syncing release tags from origin..."
git fetch origin --tags

# Function to get next phy tag number
get_next_phy_tag() {
    local max_tag=0

    # Do NOT suppress errors: if skopeo cannot reach the registry the script
    # must abort rather than silently computing phy1 and overwriting it.
    local tags_json
    tags_json=$(skopeo list-tags "docker://$REGISTRY/$NAMESPACE/$IMAGE_NAME")

    local tags=()
    mapfile -t tags < <(echo "$tags_json" | grep -o 'phy[0-9]\+' | sed 's/phy//')

    # Also consider git release tags; these may be ahead of what list-tags returns.
    local git_tags=()
    mapfile -t git_tags < <(git tag -l "${IMAGE_NAME}_phy[0-9]*" | sed 's/.*_phy//')

    for num in "${tags[@]}" "${git_tags[@]}"; do
        if [ "$num" -gt "$max_tag" ]; then
            max_tag=$num
        fi
    done

    echo $((max_tag + 1))
}

# Get next tag number
TAG_NUM=$(get_next_phy_tag)
TAG="phy$TAG_NUM"

echo "Building image: $IMAGE_NAME:$TAG"

# Build the image using podman
podman build -t "$IMAGE_NAME:$TAG" -f "$CONTAINERFILE" $(dirname "$CONTAINERFILE")

# Tag for registry
FULL_IMAGE="$REGISTRY/$NAMESPACE/$IMAGE_NAME"
podman tag "$IMAGE_NAME:$TAG" "$FULL_IMAGE:$TAG"

# Check if tag already exists — skopeo inspect: exit 0 means tag found (error),
# non-zero means not found (proceed). An unreachable registry is non-zero too,
# but since get_next_phy_tag already required a successful list-tags above, a
# failure here indicates a race and should stop the script.
if skopeo inspect --creds "$NAMESPACE":"$PASSWORD" "docker://$FULL_IMAGE:$TAG" >/dev/null 2>&1; then
    echo "Error: Tag $TAG already exists for $FULL_IMAGE"
    exit 1
fi

# Push the new tag to registry
echo "Pushing $FULL_IMAGE:$TAG"
podman push --creds "$NAMESPACE":"$PASSWORD" "$FULL_IMAGE:$TAG"

echo "Updating latest tag to point to $TAG"

# Tag locally
podman tag "$IMAGE_NAME:$TAG" "$FULL_IMAGE:latest"
    
# Push latest tag
podman push --creds "$NAMESPACE":"$PASSWORD" "$FULL_IMAGE:latest"

# Create git tag
GIT_TAG="${IMAGE_NAME}_${TAG}"
if git rev-parse "$GIT_TAG" >/dev/null 2>&1; then
    echo "Error: Git tag $GIT_TAG already exists"
    exit 1
fi

echo "Creating git tag: $GIT_TAG"
git tag "$GIT_TAG"
git push origin "$GIT_TAG"
